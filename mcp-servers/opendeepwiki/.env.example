# OpenDeepWiki — Environment Variables
# Copy to .env and fill in secrets before deploying.

# --- Runtime ---
ASPNETCORE_ENVIRONMENT=Production
URLS=http://+:8080

# --- Database ---
DB_TYPE=sqlite
CONNECTION_STRING=Data Source=/data/opendeepwiki.db

# --- Primary AI config ---
CHAT_REQUEST_TYPE=Anthropic
ENDPOINT=https://api.anthropic.com
CHAT_API_KEY=sk-ant-xxxx                       # replace with your Anthropic API key

# --- Wiki catalog generation (directory structure analysis) ---
WIKI_CATALOG_MODEL=claude-sonnet-4-6
WIKI_CATALOG_ENDPOINT=https://api.anthropic.com
WIKI_CATALOG_API_KEY=sk-ant-xxxx               # same key as above
WIKI_CATALOG_REQUEST_TYPE=Anthropic

# --- Wiki content generation (page content) ---
WIKI_CONTENT_MODEL=claude-sonnet-4-6
WIKI_CONTENT_ENDPOINT=https://api.anthropic.com
WIKI_CONTENT_API_KEY=sk-ant-xxxx               # same key as above
WIKI_CONTENT_REQUEST_TYPE=Anthropic

# --- Processing ---
WIKI_PARALLEL_COUNT=5
WIKI_LANGUAGES=en
REPOSITORIES_DIRECTORY=/data

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
