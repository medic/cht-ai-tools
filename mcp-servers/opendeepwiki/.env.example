# OpenDeepWiki — Environment Variables
# Copy to .env and fill in secrets before deploying.

# --- AI Provider ---
CHAT_MODEL=claude-sonnet-4-6
ANALYSIS_MODEL=claude-sonnet-4-6
MODEL_PROVIDER=Anthropic
ENDPOINT=https://api.anthropic.com
CHAT_API_KEY=sk-ant-xxxx                # replace with your Anthropic API key

# --- Database ---
DB_TYPE=sqlite
DB_CONNECTION_STRING=Data Source=/data/KoalaWiki.db

# --- General ---
LANGUAGE=English
TASK_MAX_SIZE_PER_USER=5
UPDATE_INTERVAL=7                       # days between automatic re-indexes
EnableSmartFilter=true
KOALAWIKI_REPOSITORIES=/repositories
